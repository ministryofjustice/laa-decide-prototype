{% extends "govuk/template.njk" %}

{% from "govuk/components/header/macro.njk" import govukHeader %}
{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "moj/components/primary-navigation/macro.njk" import mojPrimaryNavigation %}

{% block head %}
  <link href="/public/stylesheets/application.css" rel="stylesheet">
  <style>
    .moj-primary-navigation__item:first-child .moj-primary-navigation__link { color: #0b0c0c; }
    .moj-primary-navigation__item:first-child .moj-primary-navigation__link:hover { color: #0b0c0c; }
  </style>
{% endblock %}

{% block header %}
  {{ govukHeader({
    homepageUrl: "#",
    productName: "Legal Aid Agency",
    navigationClasses: "govuk-header__navigation--end",
    navigation: [
      {
        href: "#",
        text: "joann.barton@law.com"
      },
      {
        href: "#",
        text: "Sign out"
      }
    ]
  }) }}

  {{ mojPrimaryNavigation({
    label: 'Primary navigation',
    items: [
      {
        text: 'Decide if an applicant can get legal aid',
        href: '#'
      },
      {
        text: 'Open applications',
        href: '/v6/open-applications'
      },
      {
        text: 'Your list',
        href: '/v6/yourlist'
      },
      {
        text: 'Search',
        href: '/v6/search'
      }
    ]
  }) }}
{% endblock %}

{% block beforeContent %}
  {{ govukPhaseBanner({
    tag: { text: "Beta" },
    html: 'This is a new service – your <a class="govuk-link" href="#">feedback</a> will help us to improve it.'
  }) }}
  {{ govukBackLink({
    text: "Back",
    href: "javascript:history.back()"
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Check your answers</h1>

      {{ govukSummaryList({
        card: { title: { text: "Change " ~ field } },
        rows: [
          {
            key: { text: fieldName },
            value: { html: sessionData['change-new-value'] | safe },
            actions: {
              items: [{ href: "javascript:history.back()", text: "Change", visuallyHiddenText: fieldName }]
            }
          },
          {
            key: { text: "Justification" },
            value: { text: sessionData['change-justification'] },
            actions: {
              items: [{ href: "javascript:history.back()", text: "Change", visuallyHiddenText: "justification" }]
            }
          }
        ]
      }) }}

      <div style="display: flex; align-items: center; gap: 20px;">
        <form method="post" action="/v6/change/{{ reference }}/{{ field }}/confirm" style="display: inline;">
          {{ govukButton({
            text: "Confirm and save"
          }) }}
        </form>

        <p style="margin: 0;">
          <a href="javascript:history.back()" class="govuk-link">Cancel</a>
        </p>
      </div>
    </div>
  </div>
{% endblock %}
