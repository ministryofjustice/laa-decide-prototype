                      {% elif 'Physiotherapist' in priorAuthorityType %}
                        £85.50
                      {% else %}
                        £95.00
                      {% endif %}
                    </dd>
                  </div>
                  <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">Total amount requested</dt>
